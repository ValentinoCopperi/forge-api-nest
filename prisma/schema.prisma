generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id                                      Int                @id @default(autoincrement())
  name                                    String
  description                             String?
  updatedAt                               DateTime           @default(now())
  createdAt                               DateTime           @default(now())
  createdByUserId                         Int
  logoUrl                                 String?
  bannerUrl                               String?
  deletedAt                               DateTime?
  updatedByUserId                         Int?
  User_Organization_createdByUserIdToUser User               @relation("Organization_createdByUserIdToUser", fields: [createdByUserId], references: [id])
  User_Organization_updatedByUserIdToUser User?              @relation("Organization_updatedByUserIdToUser", fields: [updatedByUserId], references: [id])
  OrganizationUser                        OrganizationUser[]
  Project                                 Project[]

  @@index([createdByUserId])
  @@index([deletedAt])
  @@index([updatedByUserId])
}

model OrganizationUser {
  id             Int                  @id @default(autoincrement())
  organizationId Int
  userId         Int
  role           OrganizationUserRole @default(MEMBER)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @default(now())
  Organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  User           User                 @relation(fields: [userId], references: [id])

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model Project {
  id                                 Int           @id @default(autoincrement())
  name                               String
  description                        String?
  organizationId                     Int
  createdAt                          DateTime      @default(now())
  updatedAt                          DateTime      @default(now())
  managerId                          Int
  createdByUserId                    Int?
  deletedAt                          DateTime?
  status                             ProjectStatus @default(ACTIVE)
  User_Project_createdByUserIdToUser User?         @relation("Project_createdByUserIdToUser", fields: [createdByUserId], references: [id])
  User_Project_managerIdToUser       User          @relation("Project_managerIdToUser", fields: [managerId], references: [id])
  Organization                       Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  Task                               Task[]

  @@index([createdAt])
  @@index([organizationId])
  @@index([createdByUserId])
  @@index([deletedAt])
  @@index([managerId])
}

model Session {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Task {
  id                           Int           @id @default(autoincrement())
  title                        String
  description                  String?
  status                       TaskStatus    @default(PENDING)
  category                     TaskCategory  @default(OTRO)
  createdAt                    DateTime      @default(now())
  deadline                     DateTime?
  designatedBy                 Int?
  designatedTo                 Int?
  priority                     TaskPriority  @default(MEDIUM)
  projectId                    Int?
  updatedAt                    DateTime      @default(now())
  deletedAt                    DateTime?
  createdBy                    Int
  User_Task_createdByToUser    User          @relation("Task_createdByToUser", fields: [createdBy], references: [id])
  User_Task_designatedByToUser User?         @relation("Task_designatedByToUser", fields: [designatedBy], references: [id])
  User_Task_designatedToToUser User?         @relation("Task_designatedToToUser", fields: [designatedTo], references: [id])
  Project                      Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  TaskComment                  TaskComment[]

  @@index([designatedBy])
  @@index([designatedTo])
  @@index([projectId])
  @@index([deletedAt])
  @@index([status])
}

model TaskComment {
  id        Int       @id @default(autoincrement())
  content   String
  taskId    Int
  userId    Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now())
  deletedAt DateTime?
  Task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  User      User      @relation(fields: [userId], references: [id])

  @@index([taskId])
  @@index([userId])
  @@index([deletedAt])
}

model User {
  id                                              Int                @id @default(autoincrement())
  name                                            String
  email                                           String             @unique
  passwordHash                                    String
  avatarUrl                                       String?
  createdAt                                       DateTime           @default(now())
  updatedAt                                       DateTime           @default(now())
  Organization_Organization_createdByUserIdToUser Organization[]     @relation("Organization_createdByUserIdToUser")
  Organization_Organization_updatedByUserIdToUser Organization[]     @relation("Organization_updatedByUserIdToUser")
  OrganizationUser                                OrganizationUser[]
  Project_Project_createdByUserIdToUser           Project[]          @relation("Project_createdByUserIdToUser")
  Project_Project_managerIdToUser                 Project[]          @relation("Project_managerIdToUser")
  Session                                         Session[]
  Task_Task_createdByToUser                       Task[]             @relation("Task_createdByToUser")
  Task_Task_designatedByToUser                    Task[]             @relation("Task_designatedByToUser")
  Task_Task_designatedToToUser                    Task[]             @relation("Task_designatedToToUser")
  TaskComment                                     TaskComment[]
  UserRole                                        UserRole[]
}

model UserRole {
  userId     Int
  role       Role
  assignedAt DateTime @default(now())
  User       User     @relation(fields: [userId], references: [id])

  @@id([userId, role])
}

enum OrganizationUserRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum Role {
  DIRECTOR
  GERENTE
  EMPLEADO
}

enum TaskCategory {
  DESARROLLO
  DISENO
  TESTING
  DOCUMENTACION
  OTRO
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  OVERDUE
}

enum ProjectStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
  DELETED
  PAUSED
  CANCELLED
  COMPLETED
}
